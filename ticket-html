<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>BookMyShow · Book Tickets</title>
  <link rel="stylesheet" href="ticket.css"/>
</head>
<body>

<nav>
  <div class="nav-logo">Book<span>MyShow</span></div>
  <div class="nav-links">
    <a href="#">Movies</a>
    <a href="#">Events</a>
    <a href="#">Sports</a>
    <a href="#">Activities</a>
  </div>
  <button class="nav-sign">Sign In</button>
</nav>

<main>

  <div class="movie-panel">
    <div class="poster">
      <div class="poster-glow"></div>
      <div class="poster-badge">IMAX 3D</div>
      <div class="poster-emoji">🌌</div>
      <div class="poster-title">Galactic Storm</div>
      <div class="poster-genre">Sci-Fi · Action</div>
    </div>
    <div class="movie-meta">
      <div class="meta-row"><span class="label">Language</span><span class="value">English</span></div>
      <div class="meta-row"><span class="label">Duration</span><span class="value">2h 18m</span></div>
      <div class="meta-row"><span class="label">Release</span><span class="value">12 May 2024</span></div>
      <div class="meta-row"><span class="label">Price/ticket</span><span class="value">₹299</span></div>
      <div class="rating-row">
        <span class="stars">★★★★★</span>
        <span class="rating-val">8.6</span>
        <span class="rating-count">(12.4K votes)</span>
      </div>
    </div>
  </div>

  <div class="booking-panel">
    <div class="booking-header">
      <h2>Book Tickets — Galactic Storm</h2>
      <p>PVR INOX, Forum Mall · Saturday, 18 May</p>
    </div>

    <p class="section-title">Select Showtime</p>
    <div class="showtime-row">
      <div class="showtime selected" onclick="selectShow(this)">10:00 AM</div>
      <div class="showtime" onclick="selectShow(this)">1:30 PM</div>
      <div class="showtime" onclick="selectShow(this)">4:45 PM</div>
      <div class="showtime" onclick="selectShow(this)">8:00 PM</div>
    </div>

    <p class="section-title">Your Details</p>
    <div class="fields-grid">
      <div class="field" id="f-tickets">
        <label>Tickets <span class="hint">1 – 10</span></label>
        <input type="number" id="tickets" min="1" max="10" required placeholder="e.g. 3"/>
        <span class="msg" id="m-tickets"></span>
      </div>
      <div class="field" id="f-seat">
        <label>Seat No. <span class="hint">1 – 200</span></label>
        <input type="number" id="seat" min="1" max="200" required placeholder="e.g. 47"/>
        <span class="msg" id="m-seat"></span>
      </div>
      <div class="field" id="f-mobile">
        <label>Mobile <span class="hint">10 digits</span></label>
        <input type="tel" id="mobile" pattern="[6-9][0-9]{9}" maxlength="10" required placeholder="e.g. 9876543210"/>
        <span class="msg" id="m-mobile"></span>
      </div>
      <div class="field" id="f-email">
        <label>Email <span class="hint">for e-ticket</span></label>
        <input type="email" id="email" required placeholder="e.g. arjun@gmail.com"/>
        <span class="msg" id="m-email"></span>
      </div>
    </div>

    <div class="summary">
      <p class="summary-title">Booking Summary</p>
      <div class="summary-row"><span class="s-label">Movie</span><span class="s-value">Galactic Storm (IMAX 3D)</span></div>
      <div class="summary-row"><span class="s-label">Tickets</span><span class="s-value" id="s-tickets">—</span></div>
      <div class="summary-row"><span class="s-label">Seat</span><span class="s-value" id="s-seat">—</span></div>
      <hr class="summary-divider"/>
      <div class="summary-row total"><span class="s-label">Total</span><span class="s-value" id="s-total">—</span></div>
    </div>

    <button class="btn-book" onclick="confirmBooking()">Proceed to Payment →</button>
    <div id="confirm"></div>
  </div>

</main>

<script src="ticket.js"></script>

</body>
</html>
